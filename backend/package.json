{
  "name": "radar-backend",
  "version": "0.1.0",
  "description": "Radar — Backend API para detección de señales de mercado",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node src/seed/seed.ts",
    "backfill": "ts-node src/seed/backfill.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.3",
    "node-cron": "^3.0.3",
    "snoowrap": "^1.23.0",
    "google-trends-api": "^4.9.2",
    "string-similarity": "^4.0.4",
    "natural": "^6.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",

    "@types/string-similarity": "^4.0.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
