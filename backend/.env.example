# ============================================================
# RADAR — Backend Environment Variables
# Copiar este archivo como .env y completar las credenciales
# ============================================================

# Servidor
PORT=4000
NODE_ENV=development

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# ============================================================
# MongoDB Atlas
# Crear cluster en https://cloud.mongodb.com (Free Tier M0)
# Connection string: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/radar
# ============================================================
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_PASSWORD@cluster0.xxxxx.mongodb.net/radar?retryWrites=true&w=majority

# ============================================================
# Reddit API — App tipo "script" (NO usar Devvit, es distinto)
#
# Pasos:
# 1. Ir a https://www.reddit.com/prefs/apps (logueado con tu cuenta de Reddit)
# 2. Click en "create another app..." al final de la página
# 3. Elegir tipo "script"
# 4. Nombre: radar  |  redirect uri: http://localhost:4000  (obligatorio)
# 5. Click "create app"
# 6. client_id = string corto que aparece DEBAJO del nombre de la app
#    (a la izquierda, bajo "personal use script")
# 7. secret = campo "secret" visible en la misma pantalla
#
# REDDIT_USERNAME/PASSWORD = tu propia cuenta de Reddit
# (quedan solo en .env local, nunca se commitean gracias a .gitignore)
# User agent formato: "radar:v0.1.0 (by /u/TU_USUARIO)"
# ============================================================
REDDIT_CLIENT_ID=TU_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=TU_REDDIT_CLIENT_SECRET
REDDIT_USERNAME=TU_USUARIO_REDDIT
REDDIT_PASSWORD=TU_PASSWORD_REDDIT
REDDIT_USER_AGENT=radar:v0.1.0 (by /u/TU_USUARIO_REDDIT)

# ============================================================
# Google OAuth — FASE 2 (dejar vacío por ahora)
# Crear en https://console.cloud.google.com
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
JWT_SECRET=cambiar_esto_por_un_secreto_largo_y_aleatorio
