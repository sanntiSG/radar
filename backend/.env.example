# === Radar Backend ===

# MongoDB Atlas — pega aquí tu cadena de conexión (obligatorio)
# Ejemplo: mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/radar?retryWrites=true&w=majority
MONGODB_URI=

# Puerto del servidor
PORT=4000

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:3000

# --- Reddit (OPCIONAL) ---
# El adaptador funciona sin credenciales usando los endpoints públicos .json
# Si creas una app "script" en https://www.reddit.com/prefs/apps las usa para mayor rate limit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- Google OAuth (Fase 2) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Activar cron jobs de recolección automática (true/false)
ENABLE_CRON=true
